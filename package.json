{
  "name": "logicanchor",
  "displayName": "LogicAnchor",
  "description": "Smart, persistent context layer with line-tracking, categories, and inline ghost previews for complex codebases.",
  "version": "0.0.2",
  "publisher": "bilalmlkdev",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/byllzz/logicanchor-vscode"
  },
  "keywords": [
    "documentation",
    "context",
    "notes",
    "architecture",
    "productivity",
    "bookmarks",
    "knowledge-base",
    "registry"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Productivity"
  ],
  "activationEvents": [
    "onView:logicAnchorView"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "logicanchor-sidebar",
          "title": "LogicAnchor",
          "icon": "resources/logicanchor.svg"
        }
      ]
    },
    "views": {
      "logicanchor-sidebar": [
        {
          "type": "webview",
          "id": "logicAnchorView",
          "name": "Insight Registry"
        }
      ]
    },
    "commands": [
      {
        "command": "logicanchor.addNote",
        "title": "LogicAnchor: Pin Insight to Line"
      },
      {
        "command": "logicanchor.clearAll",
        "title": "LogicAnchor: Clear All Workspace Insights",
        "category": "LogicAnchor"
      }
    ],
    "keybindings": [
      {
        "command": "logicanchor.addNote",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "logicanchor.addNote",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "eslint": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0"
  }
}
