{
  "name": "logicanchor",
  "displayName": "LogicAnchor",
  "description": "Smart, line-stable context layers with categorized insights and inline ghost previews.",
  "version": "0.0.6",
  "publisher": "bilalmlkdev",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/byllzz/logicanchor-vscode"
  },
  "keywords": [
    "documentation",
    "context",
    "notes",
    "architecture",
    "productivity",
    "bookmarks",
    "knowledge-base",
    "registry"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onView:logicAnchorView"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "logicanchor-sidebar",
          "title": "LogicAnchor(Ctrl+Alt+A)",
          "icon": "resources/logicanchor.svg"
        }
      ]
    },
    "views": {
      "logicanchor-sidebar": [
        {
          "type": "webview",
          "id": "logicAnchorView",
          "name": "Insight Registry"
        }
      ]
    },
    "commands": [
      {
        "command": "logicanchor.addNote",
        "title": "LogicAnchor: Pin Insight to Line",
        "category": "LogicAnchor",
        "icon": "$(add)"
      },
      {
        "command": "logicanchor.clearAll",
        "title": "LogicAnchor: Clear All Workspace Insights",
        "category": "LogicAnchor",
        "icon": "$(trash)"
      },
      {
        "command": "logicanchor.openRepo",
        "title": "LogicAnchor: Open GitHub Repository",
        "category": "LogicAnchor",
        "icon": "$(github)"
      },
      {
        "command": "logicanchor.reportIssue",
        "title": "LogicAnchor: Report an Issue",
        "category": "LogicAnchor",
        "icon": "$(report)"
      },
      {
        "command": "logicanchor.nextInsight",
        "title": "LogicAnchor: Next Insight"
      },
      {
        "command": "logicanchor.prevInsight",
        "title": "LogicAnchor: Previous Insight"
      },
      {
        "command": "logicanchor.generateMap",
        "title": "LogicAnchor: Generate Project Logic Map (MD)",
        "category": "LogicAnchor",
        "icon": "$(markdown)"
      },
      {
        "command": "logicanchor.projectHealth",
        "title": "LogicAnchor: Check Project Documentation Health",
        "category": "LogicAnchor",
        "icon": "$(pulse)"
      },
      {
        "command": "logicanchor.cleanupOrphans",
        "title": "LogicAnchor: Clean Up Orphaned Notes",
        "category": "LogicAnchor",
        "icon": "$(clear-all)"
      }
    ],
    "keybindings": [
      {
        "command": "logicanchor.addNote",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "logicanchor.nextInsight",
        "key": "alt+down",
        "when": "editorTextFocus"
      },
      {
        "command": "logicanchor.prevInsight",
        "key": "alt+up",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "logicanchor.addNote",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "logicanchor.addNote",
          "when": "view == logicAnchorView",
          "group": "navigation@1"
        },
        {
          "command": "logicanchor.generateMap",
          "when": "view == logicAnchorView",
          "group": "navigation@1.1"
        },
        {
          "command": "logicanchor.projectHealth",
          "when": "view == logicAnchorView",
          "group": "navigation@1.2"
        },
        {
          "command": "logicanchor.cleanupOrphans",
          "when": "view == logicAnchorView",
          "group": "navigation@2"
        },
        {
          "command": "logicanchor.clearAll",
          "when": "view == logicAnchorView",
          "group": "navigation@2.1"
        },
        {
          "command": "logicanchor.openRepo",
          "when": "view == logicAnchorView",
          "group": "navigation@3"
        },
        {
          "command": "logicanchor.reportIssue",
          "when": "view == logicAnchorView",
          "group": "navigation@4"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "eslint": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0"
  }
}
